rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Page views — authenticated users can write their own
    match /pageViews/{doc} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && request.auth.token.email == 'krishnavamsikaruturi8@gmail.com';
    }

    // Users collection — users can write their own doc, admin can read all
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.email == 'krishnavamsikaruturi8@gmail.com';
    }

    // Engagement — authenticated users can write their own
    match /engagement/{doc} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && request.auth.token.email == 'krishnavamsikaruturi8@gmail.com';
    }

    // Comments — anyone can read, authenticated users can create their own
    match /page_comments/{doc} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.auth.token.email == 'krishnavamsikaruturi8@gmail.com'
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.auth.token.email == 'krishnavamsikaruturi8@gmail.com'
      );
    }

    // Newsletter subscribers — authenticated users can subscribe, admin can read
    match /newsletter_subscribers/{doc} {
      allow create, update: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.email == 'krishnavamsikaruturi8@gmail.com';
    }

    // Page feedback (thumbs up/down) — authenticated users can write
    match /page_feedback/{doc} {
      allow create, update: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.email == 'krishnavamsikaruturi8@gmail.com';
    }
  }
}
